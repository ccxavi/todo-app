<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Monochrome Palette -->
    <Color x:Key="Background">#F7F7F7</Color>
    <Color x:Key="BackgroundDark">#111111</Color>
    <Color x:Key="Surface">#FFFFFF</Color>
    <Color x:Key="SurfaceDark">#1C1C1C</Color>
    <Color x:Key="OnSurface">#111111</Color>
    <Color x:Key="OnSurfaceDark">#F0F0F0</Color>
    <Color x:Key="Muted">#909090</Color>
    <Color x:Key="MutedDark">#6B6B6B</Color>
    <Color x:Key="Border">#E0E0E0</Color>
    <Color x:Key="BorderDark">#2E2E2E</Color>
    <Color x:Key="Accent">#111111</Color>
    <Color x:Key="AccentDark">#F0F0F0</Color>

    <!-- Danger -->
    <Color x:Key="Danger">#E53935</Color>
    <Color x:Key="DangerDark">#EF9A9A</Color>

    <!-- Grays -->
    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Gray100">#F5F5F5</Color>
    <Color x:Key="Gray200">#E0E0E0</Color>
    <Color x:Key="Gray300">#C7C7C7</Color>
    <Color x:Key="Gray400">#ADADAD</Color>
    <Color x:Key="Gray500">#909090</Color>
    <Color x:Key="Gray600">#6B6B6B</Color>
    <Color x:Key="Gray700">#4A4A4A</Color>
    <Color x:Key="Gray800">#333333</Color>
    <Color x:Key="Gray900">#1E1E1E</Color>
    <Color x:Key="Gray950">#111111</Color>

    <!-- Aliases kept for default MAUI styles referencing them -->
    <Color x:Key="Primary">#111111</Color>
    <Color x:Key="PrimaryDark">#F0F0F0</Color>
    <Color x:Key="PrimaryDarkText">#111111</Color>
    <Color x:Key="Secondary">#E0E0E0</Color>
    <Color x:Key="SecondaryDarkText">#C7C7C7</Color>
    <Color x:Key="Tertiary">#4A4A4A</Color>
    <Color x:Key="OffBlack">#1C1C1C</Color>
    <Color x:Key="MidnightBlue">#111111</Color>
    <Color x:Key="Magenta">#111111</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Surface}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource Border}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>
    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>

</ResourceDictionary>