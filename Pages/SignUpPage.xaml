<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDoApplication.SignUpPage"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,20"
            Spacing="25">

            <Image
                Source="dotnet_bot.png"
                HeightRequest="185"
                Aspect="AspectFit" />

            <VerticalStackLayout Spacing="10">
                <Entry Placeholder="Enter your full name" />

                <Entry Placeholder="Enter your email" Keyboard="Email" />

                <Entry Placeholder="Create a password" IsPassword="True" />

                <Entry Placeholder="Confirm password" IsPassword="True" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="10">
                <Button Text="Sign Up" />

                <Button Text="Sign In" Clicked="OnSignInClicked" />
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
