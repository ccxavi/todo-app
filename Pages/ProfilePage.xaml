<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDoApplication.ProfilePage"
             Shell.NavBarIsVisible="False">

    <Grid
        Padding="0,16,0,0"
        RowDefinitions="Auto,*">
        <VerticalStackLayout
            Grid.Row="0"
            Spacing="12">
            <Label
                FontAttributes="Bold"
                FontSize="24"
                HorizontalOptions="Center"
                Text="Profile" />

            <BoxView
                HeightRequest="1"
                Margin="14,0"
                Opacity="0.2" />
        </VerticalStackLayout>

        <VerticalStackLayout
            Grid.Row="1"
            HorizontalOptions="Center"
            Spacing="24"
            VerticalOptions="Center"
            Padding="20">
            
            <Image
                Source="logo.png"
                HeightRequest="150"
                Aspect="AspectFit" />

            <!-- Commented out for testing:
            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                <Label Text="{Binding id, StringFormat='User ID: {0}'}" 
                       FontSize="14" 
                       TextColor="Gray" 
                       HorizontalOptions="Center" />
                
                <Label Text="{Binding fname, StringFormat='Hello, {0}'}" 
                       FontSize="20" 
                       FontAttributes="Bold" 
                       HorizontalOptions="Center" />
                
                <Label Text="{Binding email}" 
                       FontSize="16" 
                       HorizontalOptions="Center" />
            </VerticalStackLayout>
            -->

            <Button
                Clicked="OnSignOutClicked"
                Text="Sign Out" 
                WidthRequest="200"
                HorizontalOptions="Center"/>
        </VerticalStackLayout>
    </Grid>

</ContentPage>
