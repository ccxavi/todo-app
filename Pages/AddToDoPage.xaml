<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDoApplication.AddToDoPage"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False">

    <Grid Padding="0,16,0,0" RowDefinitions="Auto,*">
        
        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Spacing="12">
            <Grid Padding="16,0">
                <Grid HorizontalOptions="Start" 
                      VerticalOptions="Center" 
                      ColumnDefinitions="Auto,Auto"
                      ColumnSpacing="0">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackClicked" />
                    </Grid.GestureRecognizers>
                    <Label Grid.Column="0"
                           Text="‹" 
                           FontSize="40" 
                           VerticalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"
                           Margin="0,0,0,8"/> 
                    <Label Grid.Column="1"
                           Text="Back" 
                           FontSize="16"
                           Margin="4,0,0,0"
                           VerticalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>
                </Grid>
                
                <Label x:Name="PageTitle"
                       Text="Add"
                       FontAttributes="Bold"
                       FontSize="24"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray300}}" />
            </Grid>

            <BoxView HeightRequest="1" Margin="14,0" Opacity="0.2" />
        </VerticalStackLayout>

        <!-- Form -->
        <Grid Grid.Row="1" Padding="20,24,20,16">
            <Border VerticalOptions="Start"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
                    Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 16">
                <Border.Shadow>
                    <Shadow Brush="{AppThemeBinding Light=#10000000, Dark=#20000000}"
                            Offset="0,2"
                            Radius="8"
                            Opacity="1"/>
                </Border.Shadow>

                <VerticalStackLayout Padding="20" Spacing="16">
                    
                    <VerticalStackLayout Spacing="4">
                        <Label Text="TITLE" 
                               FontFamily="InterSemiBold"
                               FontSize="12"
                               CharacterSpacing="1"
                               TextColor="{AppThemeBinding Light={StaticResource Muted}, Dark={StaticResource MutedDark}}" 
                               Margin="0,0,0,2"/>
                        
                        <VerticalStackLayout Spacing="0">
                            <Entry x:Name="TitleEntry"
                                   Placeholder="What needs to be done?"
                                   PlaceholderColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}"
                                   FontFamily="InterRegular"
                                   FontSize="16"
                                   TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"
                                   ClearButtonVisibility="WhileEditing"
                                   BackgroundColor="Transparent" />
                            <BoxView HeightRequest="1"
                                     BackgroundColor="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"/>
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="DETAILS" 
                               FontFamily="InterSemiBold"
                               FontSize="12"
                               CharacterSpacing="1"
                               TextColor="{AppThemeBinding Light={StaticResource Muted}, Dark={StaticResource MutedDark}}" 
                               Margin="0,4,0,2"/>
                        
                        <Editor x:Name="DetailsEditor"
                                Placeholder="Add some details..."
                                PlaceholderColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}"
                                FontFamily="InterRegular"
                                FontSize="16"
                                TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"
                                AutoSize="TextChanges"
                                MinimumHeightRequest="100" />
                    </VerticalStackLayout>
                    
                    <VerticalStackLayout Spacing="16" Margin="0,32,0,0">
                        <Button x:Name="SaveButton"
                                Text="Save"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" 
                                TextColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Black}}"
                                CornerRadius="8"
                                FontAttributes="Bold"
                                FontSize="16"
                                HeightRequest="50"
                                Clicked="OnAddClicked" />

                        <Button x:Name="DeleteButton"
                                Text="Delete"
                                BackgroundColor="Transparent" 
                                TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}"
                                BorderColor="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                BorderWidth="1"
                                CornerRadius="8"
                                FontAttributes="Bold"
                                FontSize="16"
                                HeightRequest="50"
                                IsVisible="False"
                                Clicked="OnDeleteClicked" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
        </Grid>
        
    </Grid>

</ContentPage>
