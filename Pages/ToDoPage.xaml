<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDoApplication.ToDoPage"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False">


    <Grid RowDefinitions="Auto,*,Auto" Padding="0,16,0,0">
        
        <VerticalStackLayout Grid.Row="0"
                             Spacing="12">
            <Label Text="To-Do List"
                   FontAttributes="Bold"
                   FontSize="24"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}"/>

            <BoxView
                HeightRequest="1"
                Margin="14,0"
                Opacity="0.2" />
        </VerticalStackLayout>

        <Grid Grid.Row="1" Padding="24,16,24,16">
            <Border BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
                    Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 16">
                <Border.Shadow>
                    <Shadow Brush="{AppThemeBinding Light=#10000000, Dark=#20000000}"
                            Offset="0,2"
                            Radius="8"
                            Opacity="1"/>
                </Border.Shadow>

                <Grid RowDefinitions="Auto,Auto,*">
                    <!-- Card Header -->
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Padding="20,16,20,16">
                        <HorizontalStackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center">
                            <Label Text="TASKS"
                                   FontFamily="InterSemiBold"
                                   FontSize="12"
                                   CharacterSpacing="1"
                                   TextColor="{AppThemeBinding Light={StaticResource Muted}, Dark={StaticResource MutedDark}}"/>
                        </HorizontalStackLayout>
                    </Grid>

                    <BoxView Grid.Row="1" 
                             HeightRequest="1"
                             BackgroundColor="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"/>

                    <!-- List Content -->
                    <CollectionView Grid.Row="2"
                              x:Name="ToDoCollectionView"
                              ItemsSource="{Binding .}"
                              SelectionChanged="OnSelectionChanged"
                              SelectionMode="Single"
                              BackgroundColor="Transparent"
                              Margin="0,8,0,8">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12" Padding="20,12" BackgroundColor="Transparent">
                                        
                                        <CheckBox Grid.Column="0" 
                                                  IsChecked="{Binding IsCompleted}" 
                                                  VerticalOptions="Center"
                                                  Color="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" />
                                        
                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                            <Label Text="{Binding item_name}" 
                                                   FontFamily="InterSemiBold"
                                                   FontSize="16"
                                                   TextColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}" />
                                            <Label Text="{Binding item_description}" 
                                                   FontFamily="InterRegular"
                                                   FontSize="14"
                                                   TextColor="{AppThemeBinding Light={StaticResource Muted}, Dark={StaticResource MutedDark}}" />
                                        </VerticalStackLayout>
                                    </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>                </Grid>
            </Border>

            <!-- Floating Action Button -->
            <ImageButton Source="plus.png"
                         BackgroundColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
                         CornerRadius="28"
                         WidthRequest="56"
                         HeightRequest="56"
                         HorizontalOptions="End"
                         VerticalOptions="End"
                         Margin="16"
                         Padding="16"
                         Clicked="OnAddClicked">
                <ImageButton.Shadow>
                    <Shadow Brush="{AppThemeBinding Light=#20000000, Dark=#40000000}" Offset="0,4" Radius="8" Opacity="1"/>
                </ImageButton.Shadow>
            </ImageButton>
        </Grid>

        <VerticalStackLayout
            Grid.Row="2"
            Padding="14,10,14,18"
            Spacing="12">
            <BoxView HeightRequest="1" Opacity="0.2" />

            <Grid ColumnDefinitions="*,*,*">
                <Button
                    Grid.Column="0"
                    Clicked="OnToDoClicked"
                    IsEnabled="False"
                    Text="ToDo" />

                <Button
                    Grid.Column="1"
                    Clicked="OnCompletedClicked"
                    Text="Completed" />

                <Button
                    Grid.Column="2"
                    Clicked="OnProfileClicked"
                    Text="Profile" />
            </Grid>
        </VerticalStackLayout>
    </Grid>

</ContentPage>
