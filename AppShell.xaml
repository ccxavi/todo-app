<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ToDoApplication.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:ToDoApplication"
    Title="ToDoApplication"
    FlyoutBehavior="Disabled">

    <ShellContent
        Title="Sign In"
        ContentTemplate="{DataTemplate local:SignInPage}"
        Route="SignInPage" />

    <TabBar
        Route="AppTabs"
        Shell.TabBarBackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
        Shell.TabBarForegroundColor="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource Gray100}}"
        Shell.TabBarUnselectedColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray500}}">
        <ShellContent
            Title="ToDo"
            Icon="planner.svg"
            ContentTemplate="{DataTemplate local:ToDoPage}"
            Route="ToDoPage" />

        <ShellContent
            Title="Completed"
            Icon="check.svg"
            ContentTemplate="{DataTemplate local:CompletedPage}"
            Route="CompletedPage" />

        <ShellContent
            Title="Profile"
            Icon="profile.svg"
            ContentTemplate="{DataTemplate local:ProfilePage}"
            Route="ProfilePage" />
    </TabBar>

</Shell>
